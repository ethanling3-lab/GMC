# Copy this to scripts/.migration.env and fill in the four values.
# The real file is gitignored (matches .env*) — never commit it.
#
# Find the WABA IDs in Meta Business Manager → WhatsApp Manager → API Setup,
# labeled "WhatsApp Business Account ID". One for the test (source) account,
# one for the official (target) account.
#
# Use a permanent system-user access token for each. Token scopes required:
#   whatsapp_business_messaging
#   whatsapp_business_management

WHATSAPP_SOURCE_WABA_ID=
WHATSAPP_SOURCE_ACCESS_TOKEN=

WHATSAPP_TARGET_WABA_ID=
WHATSAPP_TARGET_ACCESS_TOKEN=
